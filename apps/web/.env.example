# Leave empty in local development so Vite uses its /api dev proxy.
VITE_API_ORIGIN=

# Optional development-only fallback when VITE_API_ORIGIN cannot be reached.
# Leave empty in production to avoid browser local-network permission prompts.
VITE_LOCAL_API_ORIGIN=http://127.0.0.1:3100

# Same-origin production build path.
VITE_BASE_PATH=/
