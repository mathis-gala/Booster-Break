POSTGRES_DB=booster_break
POSTGRES_USER=booster_break
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://booster_break:change-me@postgres:5432/booster_break

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://127.0.0.1:3100/auth/slack/callback

API_ORIGIN=http://127.0.0.1:3100
WEB_ORIGIN=http://127.0.0.1:5173
WEB_APP_URL=http://127.0.0.1:5173

# Production API deployments should set:
# WEB_ORIGIN=https://mathis-gala.github.io
# WEB_APP_URL=https://mathis-gala.github.io/Booster-Break/

# Optional sealed product lookup. The app has built-in known booster image fallbacks.
SCRYDEX_API_KEY=
SCRYDEX_TEAM_ID=
