API_DOMAIN=booster.example.com

POSTGRES_DB=booster_break
POSTGRES_USER=booster_break
POSTGRES_PASSWORD=change-me-long-random-password
DATABASE_URL=postgresql://booster_break:change-me-long-random-password@postgres:5432/booster_break

API_ORIGIN=https://booster.example.com/api
WEB_ORIGIN=https://booster.example.com
WEB_APP_URL=https://booster.example.com

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://booster.example.com/api/auth/slack/callback
MAGIC_LINK_ADMIN_SECRET=
MAGIC_LINK_TTL_DAYS=30
DEV_AUTH_ENABLED=false

SECURE_COOKIES=true
SESSION_COOKIE_NAME=booster_break_session

# Optional sealed product lookup.
SCRYDEX_API_KEY=
SCRYDEX_TEAM_ID=

# Booster rotation defaults: 3 packs, 3 vote proposals, weekly Paris cadence.
BOOSTER_ROTATION_AVAILABLE_COUNT=3
BOOSTER_ROTATION_PROPOSAL_COUNT=3
BOOSTER_ROTATION_CADENCE_UNIT=day
BOOSTER_ROTATION_CADENCE_VALUE=7
BOOSTER_ROTATION_TIME_ZONE=Europe/Paris
BOOSTER_ROTATION_ANCHOR_LOCAL_DATE=2026-06-29
